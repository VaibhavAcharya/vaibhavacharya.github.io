---
import BaseHead from "../../components/BaseHead.astro";
import BackLink from "../../components/BackLink.astro";
import Colophon from "../../components/Colophon.astro";
import RowTable from "../../components/RowTable.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";

const posts = (await getCollection("writings")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatShortDate(d: Date): string {
    return d
        .toLocaleDateString("en-US", {
            day: "numeric",
            month: "short",
            year: "numeric",
        })
        .toLowerCase();
}

const postRows = posts.map((post) => ({
    label: formatShortDate(post.data.pubDate),
    value: post.data.title,
    href: `/writings/${post.id}/`,
    target: "_self",
}));
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`writings · ${SITE_TITLE}`}
            description={SITE_DESCRIPTION}
        />
    </head>
    <body>
        <main class="max-w-[580px] w-full mx-auto px-10 pt-20 pb-18 flex flex-col max-sm:px-6 max-sm:pt-14 max-sm:pb-12">
            <BackLink label="home" href="/" />

            <p class="font-serif italic font-normal text-[17px] text-accent mt-13 mb-3.5 [font-variation-settings:'opsz'_24]">writings</p>
            <RowTable rows={postRows} reverse />

            <Colophon />
        </main>
    </body>
</html>
