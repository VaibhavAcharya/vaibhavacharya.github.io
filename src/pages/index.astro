---
import BaseHead from "../components/BaseHead.astro";
import Colophon from "../components/Colophon.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

const previously = [
    {
        role: "product engineer",
        name: "Supernova AI",
        href: "https://www.getsupernova.ai",
    },
    { role: "web engineer", name: "Skcript", href: "https://skcript.com" },
    { role: "founder", name: "InvocationX", href: null },
    { role: "junior engineer", name: "Dukaan", href: "https://mydukaan.io" },
];

const connect = [
    {
        label: "email",
        value: "vaibhavacharya111@gmail.com",
        href: "mailto:vaibhavacharya111@gmail.com",
    },
    {
        label: "github",
        value: "github.com/VaibhavAcharya",
        href: "https://github.com/VaibhavAcharya",
    },
    {
        label: "x/twitter",
        value: "@VaibhavAcharya_",
        href: "https://x.com/VaibhavAcharya_",
    },
    {
        label: "bluesky",
        value: "vaibhavacharya.bsky.social",
        href: "https://bsky.app/profile/vaibhavacharya.bsky.social",
    },
    {
        label: "linkedin",
        value: "in/vaibhav-acharya",
        href: "https://www.linkedin.com/in/vaibhav-acharya",
    },
    {
        label: "writings",
        value: "/writings",
        href: "/writings",
    },
];
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body>
        <div class="page">
            <h1 class="hero-name fade-in">
                Vaibhav Acharya,<br />engineer.
            </h1>
            <p class="hero-lede fade-in d1">
                I work at the seam where product, design and engineering stop being separate jobs.
            </p>

            <p class="section-label fade-in d2">now</p>
            <p class="body-line fade-in d2">
                Software Engineer at <a href="https://netlify.com" target="_blank" rel="noreferrer">Netlify</a>, based in IN. I like going 0 to 1, shipping often, and operating independently. Most of what I care about lives where the web, AI and tools for builders overlap. Off hours, still building small products to find out whether they deserve to exist.
            </p>

            <p class="section-label fade-in d2">previously</p>
            <table class="row-table work fade-in d2">
                <tbody>
                    {previously.map((p) => (
                        <tr>
                            <td class="role">{p.role}</td>
                            <td class="val">
                                {p.href
                                    ? <a href={p.href} target="_blank" rel="noreferrer">{p.name}</a>
                                    : p.name}
                            </td>
                        </tr>
                    ))}
                </tbody>
            </table>

            <p class="section-label fade-in d2">connect</p>
            <table class="row-table contact fade-in d2">
                <tbody>
                    {connect.map((c) => (
                        <tr>
                            <td class="label">{c.label}</td>
                            <td class="val">
                                <a href={c.href} target={c.href.startsWith("/") ? "_self" : "_blank"} rel="noreferrer">{c.value}</a>
                            </td>
                        </tr>
                    ))}
                </tbody>
            </table>

            <div class="fade-in d3">
                <Colophon />
            </div>
        </div>
    </body>
</html>
