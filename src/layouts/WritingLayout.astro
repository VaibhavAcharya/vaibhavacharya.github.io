---
// src/layouts/WritingLayout.astro
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import BackLink from "../components/BackLink.astro";
import Colophon from "../components/Colophon.astro";
import { SITE_TITLE } from "../consts";

type Props = CollectionEntry<"writings">["data"] & { slug: string };

const { title, description, pubDate, updatedDate, slug } = Astro.props;

const formattedDate = pubDate.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "long",
    year: "numeric",
});

const formattedUpdated = updatedDate
    ? updatedDate.toLocaleDateString("en-GB", {
          day: "numeric",
          month: "long",
          year: "numeric",
      })
    : null;
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead
            title={`${title} · ${SITE_TITLE}`}
            description={description}
            image={`/og/${slug}.png`}
            type="article"
            publishedDate={pubDate}
        />
    </head>
    <body>
        <main class="max-w-[580px] w-full mx-auto px-10 pt-20 pb-18 flex flex-col max-sm:px-6 max-sm:pt-14 max-sm:pb-12">
            <BackLink label="writings" href="/writings" />

            <article>
                <h1 class="font-serif italic font-normal text-[clamp(32px,4vw,44px)] leading-[1.1] tracking-[-0.02em] text-ink m-0 mb-3 [font-variation-settings:'opsz'_48]">{title}</h1>
                <p class="font-mono [font-variant-ligatures:none] text-[11.5px] tracking-[0.02em] text-ink-soft m-0 mb-8">
                    by <a href="/" class="link">Vaibhav Acharya</a>, {formattedDate}
                    {formattedUpdated && <> · updated {formattedUpdated}</>}
                </p>
                <hr class="border-0 border-t border-rule-solid m-0 mb-8" />

                <div class="post-body">
                    <slot />
                </div>
            </article>

            <Colophon />
        </main>
    </body>
</html>

<style>
    @reference "../styles/global.css";

    .post-body {
        @apply font-sans text-[17px] leading-[1.75] text-ink-muted max-w-[62ch];
    }

    .post-body :global(p) {
        @apply m-0 mb-[1.2em];
    }

    .post-body :global(h2) {
        @apply font-serif italic font-normal text-[26px] leading-[1.2] text-ink mt-[2em] mb-[0.4em] [font-variation-settings:'opsz'_24];
    }

    .post-body :global(h3) {
        @apply font-serif italic font-normal text-xl leading-[1.3] text-ink mt-[1.6em] mb-[0.3em] [font-variation-settings:'opsz'_20];
    }

    .post-body :global(a) {
        @apply text-ink;
        /* inherits .link styles from global.css — add the class in markup or extend here */
        border-bottom: 1px solid var(--color-accent-50);
        padding-bottom: 1px;
        transition: border-color 120ms linear;
    }

    .post-body :global(a:hover) {
        border-color: var(--color-accent);
    }

    .post-body :global(code) {
        @apply font-mono [font-variant-ligatures:none] text-[0.92em] bg-[oklch(0.93_0.008_80)] px-[5px] py-[2px] rounded-[3px];
    }

    .post-body :global(pre) {
        @apply font-mono [font-variant-ligatures:none] bg-[oklch(0.93_0.008_80)] px-5 py-4 rounded-[4px] overflow-x-auto my-[1.4em] text-sm leading-[1.55];
    }

    .post-body :global(pre code) {
        @apply bg-transparent p-0 rounded-none text-[inherit];
    }

    .post-body :global(blockquote) {
        @apply font-serif italic font-normal text-xl leading-[1.5] text-ink my-[1.6em] pl-5 border-l border-accent-50;
    }

    .post-body :global(ul),
    .post-body :global(ol) {
        @apply my-4 pl-[1.6em];
    }

    .post-body :global(ul) {
        @apply list-disc;
    }

    .post-body :global(ol) {
        @apply list-decimal;
    }

    .post-body :global(li) {
        @apply my-[0.3em] pl-[0.3em];
    }

    .post-body :global(li::marker) {
        @apply text-ink-soft;
    }

    .post-body :global(hr) {
        @apply border-0 border-t border-rule-solid my-[2em];
    }

    .post-body :global(img) {
        @apply max-w-full h-auto rounded-[4px] my-[1.4em];
    }

    .post-body :global(table) {
        @apply w-full my-[1.6em] border-collapse text-[15px];
    }

    .post-body :global(th) {
        @apply font-mono [font-variant-ligatures:none] text-[12px] tracking-[0.02em] text-ink-soft font-normal text-left py-2 px-3 border-b border-rule-solid;
    }

    .post-body :global(td) {
        @apply text-[14px] leading-[1.5] text-ink-muted py-2.5 px-3 border-b border-[oklch(0.9_0.005_80)];
    }

    .post-body :global(tr:last-child td) {
        @apply border-b-0;
    }
</style>
