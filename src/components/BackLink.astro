---
// src/components/BackLink.astro
// Renders an arrow-prefixed back link.
// Examples:
//   <BackLink label="home" href="/" />          → "← home", goes to /
//   <BackLink label="writings" href="/writings" /> → "← writings", goes to /writings

interface Props {
    label: string;
    href: string;
}

const { label, href } = Astro.props;
---

<a href={href} class="font-mono [font-variant-ligatures:none] text-[11.5px] tracking-[0.04em] text-ink-soft inline-block mb-10 transition-colors duration-[120ms] ease-linear hover:text-ink">← {label}</a>
