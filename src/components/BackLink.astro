---
// src/components/BackLink.astro
// Renders an arrow-prefixed back link.
// Examples:
//   <BackLink label="home" href="/" />          → "← home", goes to /
//   <BackLink label="writing" href="/writings" /> → "← writing", goes to /writings

interface Props {
    label: string;
    href: string;
}

const { label, href } = Astro.props;
---

<a href={href} class="back-link">← {label}</a>
