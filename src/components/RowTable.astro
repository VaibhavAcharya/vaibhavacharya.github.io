---
// src/components/RowTable.astro

interface Row {
    label: string;
    value: string;
    href?: string | null;
    target?: string;
    current?: boolean;
}

interface Props {
    rows: Row[];
    class?: string;
    reverse?: boolean;
}

const { rows, class: className, reverse = false } = Astro.props;
---

<ul class:list={["list-none p-0 m-0 flex flex-col", className]}>
    {rows.map((row) => (
        reverse ? (
            <li class="flex items-baseline gap-3 py-[9px]">
                <span class="font-sans text-[15px] text-ink max-sm:text-sm min-w-0">
                    {row.href ? (
                        <a
                            href={row.href}
                            target={row.target ?? "_blank"}
                            rel="noreferrer"
                            class="link"
                        >
                            {row.value}
                        </a>
                    ) : (
                        row.value
                    )}
                </span>
                <span aria-hidden="true" class="flex-1 border-b-[0.5px] border-dotted border-rule-dot translate-y-[-4px]"></span>
                <span class="font-mono [font-variant-ligatures:none] text-[11.5px] tracking-[0.02em] text-ink-soft whitespace-nowrap text-right">
                    {row.label}
                </span>
            </li>
        ) : (
            <li class="flex items-baseline gap-3 py-[9px]">
                <span class="font-mono [font-variant-ligatures:none] text-[11.5px] tracking-[0.02em] text-ink-soft whitespace-nowrap">
                    {row.current && <span class="text-accent">currently</span>}
                    {row.current ? ` ${row.label}` : row.label}
                </span>
                <span aria-hidden="true" class="flex-1 border-b-[0.5px] border-dotted border-rule-dot translate-y-[-4px]"></span>
                <span class="font-sans text-[15px] text-ink max-sm:text-sm min-w-0 text-right">
                    {row.href ? (
                        <a
                            href={row.href}
                            target={row.target ?? "_blank"}
                            rel="noreferrer"
                            class="link"
                        >
                            {row.value}
                        </a>
                    ) : (
                        row.value
                    )}
                </span>
            </li>
        )
    ))}
</ul>
